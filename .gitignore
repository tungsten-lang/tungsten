# dSYM debug symbol bundles (Xcode/clang)
*.dSYM

# Top-level compiled binaries (forge, etc.)
forge_hello_*

# LLVM IR build artifacts
*.ll

# Unicode codepoint tables — regenerated by `tungsten build` via
