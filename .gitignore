*.codepoints
.gstack/
bin/tungsten-compiler
bin/*.new
**/*_bin
*.bak

# Spinel build artifacts — fully ignored (generated; regenerate with the
# Ruby generator / `bin/tungsten build --spinel`). NOTE: tungsten_stage0.c
# and tungsten_stage0_bundle.rb were previously tracked so external builders
# could stage0 without the Ruby generator; they are now untracked, so an
# external builder must run the generator.
implementations/spinel/build/*
implementations/c/build/*
# Symbol/type sidemaps dumped to the repo root from the stage0 bundle (generated).
/tungsten_stage0_bundle.symbols.json
/tungsten_stage0_bundle.types.json

# Vendored external dependency sources
src/
!implementations/c/src/
!implementations/c/src/**
!benchmarks/linalg/rust/src/
!benchmarks/linalg/rust/src/**
bits/*/bin/*
!bits/*/bin/*.w
!bits/*/bin/.gitkeep
.claude/*.lock
.claude/settings.local.json
build/test/

# Rust benchmark build artifacts (linalg matmul cross-language baseline).
# Cargo.lock is kept for reproducible benchmark dependency versions.
benchmarks/linalg/rust/target/

# Compiled benchmark/validation binaries (built ad hoc from sibling .w files)
benchmarks/linalg/tungsten/validate_backend

# Compiled graphics demo binary (built from doc/examples/world3d.w)
/world3d

# VS Code extension build artifacts (tools/textmate)
tools/textmate/node_modules/
tools/textmate/*.vsix

# Python bytecode from the generator scripts (scripts/gen_*.py)
__pycache__/

# Compiled benchmark binaries left with the same basename as their source
# (no extension, so not caught by any pattern above) -- regenerable.
benchmarks/nested_loops/nested_loops
benchmarks/pipeline/pipeline_odin
benchmarks/pipeline/pipeline_zig

# Matmul flip-graph campaign: compiled walker/GPU binaries, per-stage run
# logs/workdirs, and the bulk tie/beat dump POPULATION are ephemeral/
# regenerable (records/ used to be tracked when it held only a handful of
# hand-verified finds; a single fleet run now dumps hundreds-to-thousands of
# files there). When a find is worth keeping, promote/copy it to a named,
# durable file instead (e.g. metaflip/matmul_5x5_rank93_sparse_gf2.txt,
# zoo/record_table_f2.txt) rather than tracking the raw dump directory.
benchmarks/matmul/metaflip/bin/
benchmarks/matmul/metaflip/runs/
benchmarks/matmul/metaflip/records/
benchmarks/matmul/zoo/runs/

# Matmul search/: a legacy campaign scratch directory — hundreds of one-off
# numbered experiment variants (turbo*, conj*, energy*, idea2*, sym*, sw*,
# rng_*, fix*, ...), none reusable. Allowlist the handful of durable
# reference/seed assets other machinery actually imports.
benchmarks/matmul/search/*
!benchmarks/matmul/search/seed_mp93.txt
!benchmarks/matmul/search/seed_mp153.txt
!benchmarks/matmul/search/scheme23.txt
!benchmarks/matmul/search/scheme47.txt
!benchmarks/matmul/search/at_f2.npz

# metaflip flipfleet / GPU-relay binaries (rebuilt via bin/tungsten -o) + runtime scratch
benchmarks/matmul/gpu_relay
benchmarks/matmul/metaflip/flipfleet
benchmarks/matmul/metaflip/ff_gpu_seed.txt
benchmarks/matmul/metaflip/ff_gpu_best.txt
benchmarks/matmul/metaflip/ff_gpu_log.txt
benchmarks/matmul/metaflip/flipfleet_status.txt
benchmarks/matmul/metaflip/gpu_sweep_results.txt
benchmarks/matmul/metaflip/.ff_cwd.tmp
