#!/bin/bash
# bin/wit — W Interactive Tungsten (REPL)
#
# Canonical playground entry point. Equivalent to: tungsten console

# Resolve symlinks so ROOT is the real install dir even when invoked via PATH.
SELF="$0"
while [ -L "$SELF" ]; do
  LINK="$(readlink "$SELF")"
  case "$LINK" in
    /*) SELF="$LINK" ;;
    *)  SELF="$(dirname "$SELF")/$LINK" ;;
  esac
done
ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"
COMPILER="$ROOT/bin/tungsten-compiler"
RUBY_CLI="$ROOT/bin/tungsten.rb"

if [ -x "$ROOT/src/patched/ruby/ruby" ]; then
  RUBY="$ROOT/src/patched/ruby/ruby"
else
  RUBY=ruby
fi

export TUNGSTEN_VERSION="$(cat "$ROOT/VERSION" 2>/dev/null || echo dev)"
export TUNGSTEN_ROOT="$ROOT"

if [ -x "$COMPILER" ]; then
  # Compiler's internal --repl flag starts the pure-Tungsten REPL.
  # Public entry points are only `wit` and `tungsten console`.
  exec "$COMPILER" --repl "$@"
fi

# Fresh clone without a compiler: Ruby-driven REPL via the console path.
exec "$RUBY" "$RUBY_CLI" console "$@"
