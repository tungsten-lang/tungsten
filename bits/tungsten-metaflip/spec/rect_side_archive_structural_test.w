# 4x6x7 has two genuinely different exact rank-123 families.  A fresh cyclic
# image of the leader must collapse, while the catalogue family must remain a
# novel structural choice.  Capacity-one selection proves that novelty wins;
# the one-candidate arm proves the distance fallback still fills the slot.
n = 4
m = 6
p = 7
capacity = ffr_default_capacity(n, m, p)
p467leader = i64[ffr_state_size(capacity)]
p467other = i64[ffr_state_size(capacity)]
r467leader = ffr_load_scheme_cap(p467leader, root + "matmul_4x6x7_rank123_d1406_gl_frontier_gf2.txt", n, m, p, capacity, 99401, 4, 4, 1000, 500) ## i64
r467other = ffr_load_scheme_cap(p467other, root + "matmul_4x6x7_rank123_catalog_gf2.txt", n, m, p, capacity, 99402, 4, 4, 1000, 500) ## i64
p467copy = ffrdst_cycle_scheme(p467leader, n, m, p, capacity, 99403)
z = ffrdst_expect("4x6x7 families and cyclic image exact", r467leader == 123 && r467other == 123 && p467copy != nil && ffr_verify_best_exact(p467copy, n, m, p) == 1)
leader_signature = ffrda_structural_signature(p467leader) ## i64
z = ffrdst_expect("4x6x7 cyclic image collapses", ffrda_same_best(p467leader, p467copy) == 0 && leader_signature == ffrda_structural_signature(p467copy))
z = ffrdst_expect("4x6x7 distinct family remains distinct", leader_signature != ffrda_structural_signature(p467other))

pool = []
pool.push(p467copy)
pool.push(p467other)
selected = []
selected_count = ffrda_select_diverse(pool, p467leader, 1, selected) ## i64
z = ffrdst_expect("selector prefers novel 4x6x7 family", selected_count == 1 && ffrda_same_best(selected[0], p467other) == 1)

reverse_pool = []
reverse_pool.push(p467other)
reverse_pool.push(p467copy)
reverse_selected = []
reverse_count = ffrda_select_diverse(reverse_pool, p467leader, 1, reverse_selected) ## i64
z = ffrdst_expect("structural preference is arrival-order independent", reverse_count == 1 && ffrda_same_best(reverse_selected[0], selected[0]) == 1)

fallback_pool = []
fallback_pool.push(p467copy)
fallback_selected = []
fallback_count = ffrda_select_diverse(fallback_pool, p467leader, 1, fallback_selected) ## i64
z = ffrdst_expect("structural collision falls back instead of rejecting", fallback_count == 1 && ffrda_same_best(fallback_selected[0], p467copy) == 1)

# Repeat the largest signature enough times to keep its exit-only cost visible
# in routine test logs.  No timing threshold is asserted across machines.
iterations = 200 ## i64
checksum = 0 ## i64
t0 = ccall("__w_clock_ms") ## i64
i = 0 ## i64
while i < iterations
  checksum = (checksum + ffrda_structural_signature(p467leader) + ffrda_structural_signature(p467other) + i) & 9223372036854775807
  i += 1
elapsed_ms = ccall("__w_clock_ms") - t0 ## i64
signature_us = elapsed_ms * 1000 / (iterations * 2) ## i64

<< "PASS rectangular structural side-door selection signatures=" + s9a.to_s() + "/" + leader_signature.to_s() + " d467=" + ffrda_best_distance(p467leader, p467other).to_s() + " signature_us=" + signature_us.to_s() + " checksum=" + checksum.to_s()
