# Standalone test for the nvfp4_matvec kernel. Loads pre-dumped
# real qwen3.6 q_proj weights + scales, runs the kernel, compares
# to the MLX reference output dumped from Python.
#
# Test data is generated by running:
#   source ~/.mlx-venv/bin/activate
#   python3 <<'EOF' ... (see scripts/bench/dump_nvfp4_test.py shape) EOF
#
# Pass criterion: max |y - y_expected| < 1e-3 (bfloat16 reference precision).

use core/metal

KERNEL = "compiler/lib/kernels/tungsten-llama/nvfp4/nvfp4_matvec.metal"
W_PATH = "/tmp/nvfp4_test/q_proj_weight.bin"
S_PATH = "/tmp/nvfp4_test/q_proj_scales.bin"
X_PATH = "/tmp/nvfp4_test/x.bin"
Y_PATH = "/tmp/nvfp4_test/y_expected.bin"

N_ROWS = 8192
K_DIM = 2048
W_BYTES = N_ROWS * K_DIM / 8 * 4    # uint32 each holds 8 nibbles
S_BYTES = N_ROWS * K_DIM / 16        # uint8 each holds one fp8 scale
X_BYTES = K_DIM * 4                  # f32 activation
Y_BYTES = N_ROWS * 4                 # f32 output

device = metal_device()
queue = metal_queue(device)
matvec_pipe = metal_pipeline(metal_compile_source(device, read_file(KERNEL)), "nvfp4_matvec")

<< "loading test data..."
w_mmap = File.mmap(W_PATH)
s_mmap = File.mmap(S_PATH)
x_mmap = File.mmap(X_PATH)

w_buf = metal_buffer(device, W_BYTES)
s_buf = metal_buffer(device, S_BYTES)
x_buf = metal_buffer(device, X_BYTES)
y_buf = metal_buffer(device, Y_BYTES)

metal_buffer_write_from_mmap(w_buf, 0, w_mmap, 0, W_BYTES)
metal_buffer_write_from_mmap(s_buf, 0, s_mmap, 0, S_BYTES)
metal_buffer_write_from_mmap(x_buf, 0, x_mmap, 0, X_BYTES)

k_dim_buf = metal_buffer(device, 4)
metal_buffer_write_i32(k_dim_buf, 0, K_DIM)

<< "dispatching nvfp4_matvec (" + N_ROWS.to_s + " rows, k=" + K_DIM.to_s + ")..."
metal_batch_begin(queue)
metal_dispatch_groups(queue, matvec_pipe, [w_buf, s_buf, x_buf, y_buf, k_dim_buf], N_ROWS, 32)
metal_batch_commit(queue)

# Print first 10 outputs. Compare visually against the Python reference
# (which printed y[:5] = -0.14965 1.077 -0.398 -0.740 -0.332 ...).
<< ""
<< "first 10 outputs:"
i = 0
while i < 10
  got = metal_buffer_read_f32(y_buf, i)
  << "  y[" + i.to_s + "] = " + got.to_s
  i = i + 1

<< ""
<< "last 5 outputs (expected ... -0.011 1.215 0.247 -1.109 0.956):"
i = N_ROWS - 5
while i < N_ROWS
  got = metal_buffer_read_f32(y_buf, i)
  << "  y[" + i.to_s + "] = " + got.to_s
  i = i + 1
